{
  "name": "hidrate-final",
  "version": "2.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"App.tsx\" \"index.js\" \"{app,eas,package,tsconfig}.json\" \"{README,RELEASES,CHANGELOG}.md\" \"eslint.config.mjs\" \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"scripts/**/*.js\" \".github/workflows/**/*.yml\" --write",
    "format:check": "prettier \"App.tsx\" \"index.js\" \"{app,eas,package,tsconfig}.json\" \"{README,RELEASES,CHANGELOG}.md\" \"eslint.config.mjs\" \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"scripts/**/*.js\" \".github/workflows/**/*.yml\" --check",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "test": "node --experimental-strip-types --test --test-isolation=none \"tests/**/*.test.ts\"",
    "test:watch": "node --experimental-strip-types --test --test-isolation=none --watch \"tests/**/*.test.ts\"",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
